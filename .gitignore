# React Native - .gitignore
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Arquivos do Sistema Operacional (Windows/Mac)
.DS_Store
Thumbs.db

# Logs gerais e Metro bundler
*.log
.metro-health-check*

# Configurações do seu Editor de Código (VS Code, etc.)
.vscode/
.idea/

# Android (Arquivos gerados automaticamente e configurações locais)
android/app/build/
android/.gradle/
android/local.properties
android/*.iml
*.apk
*.aab

# iOS (Arquivos gerados automaticamente e Pods)
ios/Pods/
ios/build/
*.xcworkspace
!default.xcworkspace
ios/*.xcodeproj/xcuserdata/